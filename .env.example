# Simpsonville Analyzer — environment template
# Copy to .env and replace placeholders with real values:
#   cp .env.example .env
#
# Full local report rerun (local photos in media/):
#   1. python run_analysis.py
#   2. python run_roi.py
# Requires: ANTHROPIC_API_KEY, SUPABASE_URL, SUPABASE_SERVICE_KEY
# Google vars below are only for Google Photos import via the web app.

# -----------------------------------------------------------------------------
# Anthropic / Claude (required for analysis + report generation)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_VISION_MODEL=claude-sonnet-4-6
CLAUDE_TEXT_MODEL=claude-sonnet-4-6
CLAUDE_DETAIL_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Supabase (required for CLI scripts and report persistence)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME

# -----------------------------------------------------------------------------
# Google Photos OAuth (only for Google Photos import — not local media/)
# Alternative: google_credentials.json + google_token.json in repo root
# -----------------------------------------------------------------------------
GOOGLE_CREDENTIALS_JSON={"web":{"client_id":"REPLACE_ME.apps.googleusercontent.com","project_id":"REPLACE_ME","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_secret":"REPLACE_ME","redirect_uris":["http://localhost:8000/auth/callback"]}}

GOOGLE_TOKEN_JSON={"token":"REPLACE_ME","refresh_token":"REPLACE_ME","token_uri":"https://oauth2.googleapis.com/token","client_id":"REPLACE_ME.apps.googleusercontent.com","client_secret":"REPLACE_ME","scopes":["https://www.googleapis.com/auth/photoslibrary.readonly","https://www.googleapis.com/auth/photoslibrary.sharing"]}

REDIRECT_URI=http://localhost:8000/auth/callback

# -----------------------------------------------------------------------------
# Local server / deployment
# -----------------------------------------------------------------------------
PORT=8000

# -----------------------------------------------------------------------------
# ATTOM property data (file-based — NOT environment variables)
# -----------------------------------------------------------------------------
# This repo reads ATTOM from gitignored JSON files in the repo root:
#   attom_assessment.json  — AVM, beds/baths, sqft, year built
#   attom_sales.json       — last sale amount and date
#
# STATUS: both files are MISSING in this clone.
# Reports will still generate, but market value and sale-history context
# fall back to empty/placeholder values until you add those files.
# Obtain copies from the original project owner or your ATTOM export.
