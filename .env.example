# Simpsonville Analyzer environment template
# Copy to .env and replace placeholders with real values.
#
# External photo import has been removed. Existing photo_analyses and Decision
# Matrix records remain usable from Supabase. Use local media scripts only if
# new photo analysis is needed.

# Core app
PORT=8000
PROPERTY_ID=130_kingfisher

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Current AI provider
ANTHROPIC_API_KEY=
CLAUDE_MODEL=
CLAUDE_VISION_MODEL=
CLAUDE_TEXT_MODEL=
CLAUDE_DETAIL_MODEL=

# Market data
# Optional for app startup; required for live market refresh once implemented.
ATTOM_API_KEY=

# Optional future AI provider
# Reserved only; current active app paths do not use OpenAI yet.
OPENAI_API_KEY=

# Optional future address validation
# Not required for the current single-property workflow.
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=
SMARTY_LICENSE=
